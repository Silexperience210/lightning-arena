# =====================================================
# LIGHTNING ARENA - Environment Configuration
# Copy this to .env and fill in your values
# =====================================================

# Server
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lightning_arena
DB_USER=lightning
DB_PASSWORD=your_secure_password_here

# Redis (Cache)
REDIS_URL=redis://localhost:6379

# Security
# Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here_32bytes_minimum
NWC_ENCRYPTION_KEY=your_aes_256_key_here_32bytes_hex

# LND Node (Lightning) - OPTIONAL
# Set LND_ENABLED=false for NWC P2P only mode (no LND needed!)
LND_ENABLED=false
LND_GRPC_HOST=localhost:10009
LND_MACAROON_PATH=/path/to/admin.macaroon
LND_TLS_CERT_PATH=/path/to/tls.cert
# Note: NWC manages budgets natively, no server config needed

# Optional: Sentry for error tracking
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Optional: Prometheus metrics
# METRICS_ENABLED=true
# METRICS_PORT=9090
