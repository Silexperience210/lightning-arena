# Background Worker Dockerfile
FROM node:20-alpine

WORKDIR /app

# Install dependencies
RUN apk add --no-cache python3 make g++ curl

COPY package*.json ./
RUN npm ci --only=production

# Copy application
COPY . .

# Create LND credentials directory
RUN mkdir -p /app/lnd

# Run worker
CMD ["node", "src/worker.js"]
